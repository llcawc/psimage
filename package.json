{
  "name": "psimage",
  "version": "0.0.4",
  "description": "gulp plugin for optimizing and minimizing jpg/png/gif/svg images and for converting to webp and avif formats",
  "homepage": "https://github.com/llcawc/psimage",
  "license": "MIT",
  "author": "llcawc",
  "files": [
    "dist",
    "types",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/psimage.cjs",
  "module": "./dist/psimage.js",
  "types": "./dist/psimage.d.cts",
  "exports": {
    ".": {
      "import": "./dist/psimage.js",
      "require": "./dist/psimage.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest --run",
    "lint": "oxlint",
    "fix": "oxlint --fix",
    "check": "oxfmt --check",
    "fmt": "oxfmt",
    "typecheck": "tsc -p . --noEmit",
    "validate": "oxlint && tsc --noEmit",
    "tsc": "tsc -p .",
    "build": "tsdown"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "fancy-log": "^2.0.0",
    "gifsicle-neo": "^8.0.2",
    "imagemin": "^9.0.1",
    "imagemin-svgo": "^12.0.0",
    "mozjpeg": "^8.0.0",
    "optipng-bin": "^9.0.0",
    "plugin-error": "^2.0.1",
    "plur": "^6.0.0",
    "pretty-bytes": "^7.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/fancy-log": "^2.0.2",
    "@types/gulp": "^4.0.18",
    "@types/imagemin": "^9.0.1",
    "@types/imagemin-svgo": "^11.0.0",
    "@types/node": "^25.6.0",
    "@types/vinyl": "^2.0.12",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "del": "^8.0.1",
    "gulp": "^5.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vinyl": "^3.0.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
